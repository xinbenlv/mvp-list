# Anthropic API key (required for Phase 1b+; not used in Phase 0 stubs).
ANTHROPIC_API_KEY=sk-ant-...

# Enable real Anthropic API calls in tests. Default: unset/0 → cassette replay only.
RUN_LIVE_LLM=0

# When 1, agent/tools/backend.py reads poc-demo/demo_places.json instead of HTTP.
MOCK_BACKEND=1
